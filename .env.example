VITE_API_BE_URL=http://localhost:8081
VITE_API_URL=http://localhost:8080
VITE_APP_NAME=App
VITE_REFRESH_PATH=/users/refresh
# VITE_MOCK_API=true

# --- Public order-intake flow (/intake) — decoupled from the admin app ---
# Keeper host that issues guest tokens (site-key exchange).
VITE_KEEPER_URL=http://localhost:8080
# Ant order-intake host (guest-token listener); public /public/* endpoints live here.
VITE_INTAKE_URL=http://localhost:8083
# Site key is resolved at runtime from the URL via keeper GET /guest-keys/lookup
# (one build serves many tenants) — there is no VITE_GUEST_SITE_KEY. For local
# dev, register a keeper guest key with domain "localhost" (port stripped
# server-side); for a slug tenant use domain "localhost/s/<slug>".
# Google reCAPTCHA v3 site key. Leave empty in dev (backend captcha disabled).
VITE_RECAPTCHA_SITE_KEY=
